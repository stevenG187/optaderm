{"components/carousel":"<section class=\"heroCarousel{{#if theme_settings.theme_version '===' 'Sporting'}} heroCarousel--limited{{/if}}\"\n    data-slick='{\n        \"arrows\": {{arrows}},\n        \"mobileFirst\": true,\n        \"slidesToShow\": 1,\n        \"slidesToScroll\": 1,\n        \"autoplay\": true,\n        \"autoplaySpeed\": {{carousel.swap_frequency}},\n        \"lazyLoad\": \"anticipated\",\n        \"slide\": \".js-hero-slide\",\n        \"prevArrow\": \".js-hero-prev-arrow\",\n        \"nextArrow\": \".js-hero-next-arrow\"\n    }'\n    data-dots-labels='{\n        \"dotAriaLabel\": \"{{lang 'carousel.dotAriaLabel'}}\",\n        \"activeDotAriaLabel\": \"{{lang 'carousel.activeDotAriaLabel'}}\"\n    }'>\n    {{#and arrows (if carousel.slides.length '>' 1)}}\n        <button aria-label=\"{{lang 'carousel.arrowAriaLabel'}} {{carousel.slides.length}}\" class=\"js-hero-prev-arrow slick-prev slick-arrow\"></button>\n    {{/and}}\n    {{#each carousel.slides}}\n    <a href=\"{{#if url}}{{url}}{{else}}javascript:void(0);{{/if}}\" class=\"js-hero-slide\" aria-label=\"{{#if this.alt_text.length '!=' 0}}{{this.alt_text}}{{else}}{{lang 'common.carousel_slide_number' slide_number=(add @index 1)}}{{/if}}\">\n        <div class=\"heroCarousel-slide {{#if ../theme_settings.homepage_stretch_carousel_images}}stretch{{/if}} {{#if @first}}heroCarousel-slide--first{{/if}}\">\n            <div class=\"heroCarousel-image-wrapper\" {{#if image_height}}{{#if image_width}}style=\"height: {{multiply (divide image_height image_width) 100}}vw; max-height: {{multiply (divide image_height image_width) ../../../carousel_width}}px;\"{{/if}}{{/if}}>\n                <img class=\"heroCarousel-image\" {{#if @first}}src{{else}}data-lazy{{/if}}=\"{{image}}\" alt=\"{{alt_text}}\" title=\"{{alt_text}}\" {{#if image_width}}width=\"{{image_width}}\"{{/if}} {{#if image_height}}height=\"{{image_height}}\"{{/if}} />\n            </div>\n            {{#or heading text}}\n            <div class=\"heroCarousel-content--wrapper\">\n                {{#if heading}}\n                    {{> components/carousel-content show_background=true}}\n                {{else}}\n                    {{#if text}}\n                        {{> components/carousel-content show_background=true}}\n                    {{else}}\n                        {{#if button_text}}\n                            {{> components/carousel-content show_background=false}}\n                        {{/if}}\n                    {{/if}}\n                {{/if}}\n            </div>\n            {{/or}}\n        </div>\n    </a>\n    {{/each}}\n    {{#and arrows (if carousel.slides.length '>' 1)}}\n    <button aria-label=\"{{lang 'carousel.arrowAriaLabel'}} {{carousel.slides.length}}\" class=\"js-hero-next-arrow slick-next slick-arrow\"></button>\n    {{/and}}\n</section>\n","components/carousel-content":"<div class=\"heroCarousel-content{{#unless show_background}} heroCarousel-content--empty{{/unless}}\">\n    <p class=\"heroCarousel-title\">{{{heading}}}</p>\n    <p class=\"heroCarousel-description\">{{{text}}}</p>\n    {{#if button_text}}\n        <span class=\"heroCarousel-action button button--large\">{{button_text}}</span>\n    {{/if}}\n</div>\n"}
